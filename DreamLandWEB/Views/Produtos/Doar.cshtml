@model DreamLandWEB.Models.ViewModels.DoacaoViewModel
@using DreamLandWEB.Models
@using DreamLandWEB.Enums

@{
    ViewData["Title"] = "Doar ou Vender um Produto";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="dl-titulo mb-3 text-center">Doar ou Vender um Produto</h2>
        <p class="text-muted text-center mb-4">
            Preencha os dados abaixo. Seu produto passará por uma breve aprovação antes de aparecer na loja.
        </p>

        <form asp-action="Doar" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Nome" class="form-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descricao" class="form-label"></label>
                <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Categoria" class="form-label"></label>
                <select asp-for="Categoria" class="form-select" asp-items="Html.GetEnumSelectList<CategoriaProduto>()">
                    <option value="">Selecione...</option>
                </select>
                <span asp-validation-for="Categoria" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Condicao" class="form-label"></label>
                <select asp-for="Condicao" class="form-select" asp-items="Html.GetEnumSelectList<CondicaoProduto>()">
                    <option value="">Selecione...</option>
                </select>
                <span asp-validation-for="Condicao" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Tamanho" class="form-label"></label>
                <input asp-for="Tamanho" class="form-control" placeholder="Ex: P, M, G, 2 anos..." />
                <span asp-validation-for="Tamanho" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Preco" class="form-label"></label>
                <input asp-for="Preco" class="form-control" placeholder="0,00 para doação" />
                <span asp-validation-for="Preco" class="text-danger"></span>
                <div class="form-text">Deixe 0 se for doação.</div>
            </div>

            <div class="mb-3">
                <label asp-for="ImagemUrl" class="form-label">Link da Imagem</label>
                <input asp-for="ImagemUrl" class="form-control" placeholder="https://..." />
            </div>

            <button type="submit" class="btn btn-outline-primary w-100">Enviar para Aprovação</button>
        </form>
    </div>
</div>